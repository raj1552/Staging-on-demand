# Local .terraform directories
**/.terraform/*

# Terraform state files - these can contain sensitive data and are unique per environment
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, since they usually contain sensitive data or values
# specific to your own environment. terraform.tfvars.example is the template
# that SHOULD be committed, everything else here should not be.
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Ignore override files, generally used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore any generated plan output
*.tfplan

# Lambda build artifacts - these are generated by the archive_file data
# source on every terraform apply/plan, and don't need to be tracked
lambda/*.zip

# OS/editor cruft
.DS_Store
*.swp